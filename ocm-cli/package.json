{
  "name": "@opencode-manager/ocm-cli",
  "version": "0.2.2",
  "description": "OpenCode Manager CLI: attach a local OpenCode TUI to a Manager-hosted repo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chriswritescode-dev/opencode-manager.git",
    "directory": "ocm-cli"
  },
  "type": "module",
  "oc-plugin": [
    "tui"
  ],
  "exports": {
    "./tui": {
      "import": "./dist/tui.js"
    }
  },
  "bin": {
    "ocm": "./dist/ocm.js"
  },
  "files": [
    "dist",
    "README.md",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "postinstall": "node scripts/postinstall.mjs || true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "bun scripts/build.ts && vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun scripts/build.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@opencode-manager/shared": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.1.0"
  }
}
